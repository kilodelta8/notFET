<!-- app/views/groups/index.html.erb -->

<div class="wall-wrapper">
  
  <!-- Render the reusable top navigation bar -->
  <%= render 'layouts/wall_nav' %>

  <!-- Secondary Groups Navigation -->
  <nav class="secondary-nav navbar navbar-expand-lg navbar-dark">
    <div class="container-fluid">
      <div class="d-flex align-items-center">
        <i class="fas fa-users secondary-nav-icon"></i>
        <h2 class="secondary-nav-title">Groups</h2>
      </div>
      <ul class="navbar-nav">
        <li class="nav-item"><a href="#" class="nav-link active">Overview</a></li>
        <li class="nav-item"><a href="<%= explore_path %>" class="nav-link">Explore</a></li>
      </ul>
    </div>
  </nav>

  <!-- Main Content Area -->
  <main class="container-fluid wall-main-content">
    <div class="row">

      <!-- Left Sidebar: Groups List -->
      <div class="col-lg-3 left-sidebar">
        <h6 class="sidebar-heading">GROUPS YOU JOINED</h6>
        <ul class="nav flex-column groups-list">
          <!-- Placeholder loop for groups -->
          <% 5.times do |i| %>
            <li class="nav-item">
              <a href="#" class="nav-link">
                <span class="group-name">THE #1 GROUP to actually lo...</span>
                <span class="group-discussions text-muted">243<%= i %> New Discussions</span>
              </a>
            </li>
          <% end %>
           <li class="nav-item">
              <a href="#" class="nav-link">
                <span class="group-name">Cocoa & Creme Connection</span>
                <span class="group-discussions text-muted">3 New Discussions</span>
              </a>
            </li>
            <li class="nav-item">
              <a href="#" class="nav-link">
                <span class="group-name">Central Ohio Lifestyle Singles</span>
              </a>
            </li>
        </ul>
      </div>

      <!-- Center Column: Group Posts Feed -->
      <div class="col-lg-9 center-feed">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <h5 class="feed-heading mb-0">Discussions Following</h5>
          <a href="#" class="small text-muted">Mark all as read</a>
        </div>

        <!-- Loop through posts from groups -->
        <%# @group_posts.each do |post| %>
        <% 2.times do %>
          <div class="group-post-item">
            <div class="row">
              <div class="col-1">
                <img src="https://placehold.co/48x48/efefef/1a1a1a?text=U" alt="User Avatar" class="rounded-circle">
              </div>
              <div class="col-8">
                <p class="mb-0 post-title">On the hunt....</p>
                <p class="mb-0 post-breadcrumb">
                  <a href="#">Beavercreek / Xenia / Fairborn, Ohio Personals</a>
                </p>
                <p class="mb-0 post-meta text-muted">
                  Chelse_Dee9837 &middot; 11 hours ago by Chelse_Dee9837
                </p>
              </div>
              <div class="col-3 text-end">
                <button class="btn btn-sm btn-outline-light">Unfollow</button>
                <button class="btn btn-sm btn-outline-light">Mark as Unread</button>
              </div>
            </div>
          </div>
        <% end %>

      </div>

    </div>
  </main>

</div>